datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  email          String   @unique
  username       String   @unique
  name           String
  hashedPassword String
  updatedAt      DateTime @updatedAt
  emailVerified  Boolean  @default(false)
}

model Yield {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  maturity String
  value    Float
  date     DateTime

  @@unique([date, maturity])
  @@index([date])
  @@index([maturity])
}

model Prediction {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  maturity      String
  value         Float
  asOfDate      DateTime
  predictedDate DateTime

  modelType String
  horizon   Int

  @@unique([predictedDate, asOfDate, maturity, modelType, horizon])
  @@index([predictedDate])
  @@index([maturity])
  @@index([modelType])
  @@index([horizon])
}
